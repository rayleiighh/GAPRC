# Caddyfile (Configuration Réseau Local - On-Premise)
# On écoute sur le port 80 en mode HTTP pour le réseau local
http://{$DOMAIN_NAME}:80 {
    
    # 🔴 API (Node.js)
    handle /api/* {
        reverse_proxy backend:3000
    }

    # 🔴 Socket.io (WebSockets)
    handle /socket.io/* {
        reverse_proxy backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # 🔴 PWA (Vite/Nginx)
    handle {
        reverse_proxy frontend:80
    }
}